#pragma once

// Copy to onion_config.h for baked-in auth defaults. WiFi, Onion API server,
// and MQTT broker are intentionally hardcoded in firmware.
#define ONION_DEFAULT_WIFI_SSID "CIC Guest"
#define ONION_DEFAULT_WIFI_PASSWORD "1nnovation"

// The firmware ignores this for runtime API calls and uses https://oniondao.dev.
#define ONION_DEFAULT_SERVER_BASE_URL "https://oniondao.dev"
#define ONION_DEFAULT_BADGE_API_KEY ""

// The firmware ignores this for runtime MQTT calls and uses
// mqtt://shortline.proxy.rlwy.net:20928.
#define ONION_DEFAULT_MQTT_URI "mqtt://shortline.proxy.rlwy.net:20928"
#define ONION_DEFAULT_MQTT_USERNAME "oniondao"
#define ONION_DEFAULT_MQTT_PASSWORD "02eb3d5e04fd2dc9cbb6f3f5c6c9d89d9c96acd987cc24ddf9f717f9480e8786"
#define ONION_DEFAULT_MQTT_TOPIC_PREFIX "oniondao"

// Optional JSON manifest:
// { "scripts": [{ "name": "hello.lua", "url": "https://...", "autorun": false }] }
#define ONION_DEFAULT_SCRIPT_MANIFEST_URL ""

